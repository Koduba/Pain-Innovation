{
  "version": 2,
  "name": "delphi-survey",
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": "public",
  "framework": null,
  "installCommand": "echo 'No dependencies needed for static site'",
  "rewrites": [
    {
      "source": "/",
      "destination": "/landing.html"
    },
    {
      "source": "/investors",
      "destination": "/investors.html"
    },
    {
      "source": "/features",
      "destination": "/features.html"
    },
    {
      "source": "/security",
      "destination": "/security.html"
    },
    {
      "source": "/integrations",
      "destination": "/integrations.html"
    },
    {
      "source": "/api-docs",
      "destination": "/api-docs.html"
    },
    {
      "source": "/user-guides",
      "destination": "/user-guides.html"
    },
    {
      "source": "/training",
      "destination": "/training.html"
    },
    {
      "source": "/research",
      "destination": "/research.html"
    },
    {
      "source": "/help-center",
      "destination": "/help-center.html"
    },
    {
      "source": "/contact-support",
      "destination": "/contact-support.html"
    },
    {
      "source": "/sla",
      "destination": "/sla.html"
    },
    {
      "source": "/survey",
      "destination": "/survey.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}

{
  "version": 2,
  "name": "delphi-survey",
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": "public",
  "framework": null,
  "installCommand": "echo 'No dependencies needed for static site'",
  "rewrites": [
    {
      "source": "/",
      "destination": "/landing.html"
    },
    {
      "source": "/investors",
      "destination": "/investors.html"
    },
    {
      "source": "/features",
      "destination": "/features.html"
    },
    {
      "source": "/survey",
      "destination": "/survey.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
